# Code Indexer Service — environment variables
# Copy to .env and fill in values.
#
# Production deployment guidance: see .planning/TEAM_DEPLOYMENT_PLAN.md and
# .planning/DEVOPS_REQUEST.md.  Anywhere a value is marked <DEVOPS-PROVIDED>
# the platform team will supply it from the `forge-prod` 1Password vault.
# Public host: https://forge.navistone.com
# All endpoints proxied through TheForge under /api/code-indexer/*

# ─── LadybugDB (embedded, no Docker required) ────────────────────────────────
# Local dev: keeps data inside the repo for easy reset.
# Prod (containerised): point at the persistent volume mount, e.g.
#   LADYBUG_DB_PATH=/var/lib/forge/cgr/graph.db
LADYBUG_DB_PATH=.cgr/graph.db
LADYBUG_BATCH_SIZE=1000

# Default repo to index when repo_path is omitted from /index requests
TARGET_REPO_PATH=.

# ─── Server bind ─────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── GitHub integration (used by /github/* routes) ───────────────────────────
# Use a fine-scoped PAT (repo + read:org) or a GitHub App installation token.
# GITHUB_TOKEN=ghp_<DEVOPS-PROVIDED>
# GITHUB_ALLOWED_OWNERS=navistone

# ─── Dense-vector semantic search ranking (default) ──────────────────────────
# Current ranking: jinaai/jina-code-embeddings-v2 (SageMaker) or in-process E5
# fallback for the local backend. (Was intfloat/e5-base-v2 across the board;
# swapped on the SageMaker side 2026-05-26 LE-129.)
# + DuckDB array_cosine_distance similarity. No rerank stage.
# Quality expectation: dense ranking is typically 85–95% of cross-encoder recall@10
# on code search benchmarks; acceptable for dogfood use.
#
# Rerank (disabled by default): When RERANK_ENABLED=true, the top-50 dense results
# for /search/semantic and /context-bundle rerank requests are reordered via an LLM.
# LM Studio was retired (TheForge PR #168). Future rerank implementations will wire
# via a different backend; see docs/SEARCH_RANKING.md and BUC-1545 for roadmap.
RERANK_ENABLED=false

# ─── Pluggable embedder backend ───────────────────────────────────────────────
# Four interchangeable backends sit behind a single protocol. The first three
# (local, sagemaker, tei) produce 768-dim vectors (sagemaker: jina-code-v2;
# local + tei: e5-base-v2 unless overridden) — DuckDB/Ladybug
# schema is unchanged, switching among them is a pure env var flip + restart.
# The fourth (openai) is BYO and produces 1536/3072-dim vectors; it requires
# a schema migration (delete .cgr/repos/*.duck and re-index). See
# docs/EMBEDDERS.md for the full comparison.
#
#   local      sentence-transformers in-process. Zero external deps.
#              Requires the [local-embed] extras (sentence-transformers>=3.2).
#              Best for: laptop / standalone evaluation / no-AWS environments.
#
#   sagemaker  Navistone AWS SageMaker Serverless Inference endpoint.
#              Requires AWS creds with sagemaker:InvokeEndpoint permission.
#              Best for: Navistone production (this is the current default
#              for the prod .env).
#
#   tei        Hugging Face Text-Embeddings-Inference HTTP sidecar.
#              Bring it up with:
#                docker run -d -p 8080:80 --gpus all \
#                  ghcr.io/huggingface/text-embeddings-inference:1.5 \
#                  --model-id intfloat/e5-base-v2
#              Best for: GPU-batched embedding without AWS or local CPU load.
#
#   openai     OpenAI /v1/embeddings (text-embedding-3-small | 3-large).
#              Requires OPENAI_API_KEY + the [byo] extras (openai>=1.0).
#              Best for: standalone operators who don't want to provision
#              AWS or download a 440MB local model.
EMBEDDER_BACKEND=local

# ─── Backend: local (sentence-transformers in-process) ────────────────────────
# Model id used by the local backend. Defaults to intfloat/e5-base-v2 (768-dim).
# Changing this will likely break the FLOAT[768] vector schema — do not unless
# you know what you're doing.
# LOCAL_EMBED_MODEL=intfloat/e5-base-v2

# ─── Backend: sagemaker (AWS SageMaker jina-code-v2) ──────────────────────────
# Was E5, swapped 2026-05-26 LE-129.
# Set EMBEDDER_BACKEND=sagemaker above to activate. Requires AWS credentials
# in the usual boto3 chain (env vars / instance profile / SSO profile).
# SAGEMAKER_ENDPOINT_NAME=jina-code-v2-serverless
# SAGEMAKER_EMBED_URL=https://runtime.sagemaker.us-east-1.amazonaws.com/endpoints/jina-code-v2-serverless/invocations
# SAGEMAKER_EMBED_REGION=us-east-1
# SAGEMAKER_EMBED_BATCH_SIZE=32

# ─── Backend: tei (Hugging Face Text-Embeddings-Inference sidecar) ────────────
# Set EMBEDDER_BACKEND=tei above to activate. TEI_URL points at the sidecar.
# TEI_URL=http://localhost:8080
# TEI_TIMEOUT_MS=30000
# TEI_BATCH_SIZE=32

# ─── Backend: openai (BYO — OpenAI /v1/embeddings) ────────────────────────────
# Set EMBEDDER_BACKEND=openai above to activate. The recommended "bring your
# own" path — no model download, no AWS account, just an API key. Install the
# optional dep with: uv sync --extra byo
#
# Default model produces 1536-dim vectors; the existing schema is FLOAT[768].
# Either set OPENAI_EMBED_DIM=768 (Matryoshka truncation — 3-series only) or
# delete .cgr/repos/*.duck and re-index. See docs/EMBEDDERS.md.
# OPENAI_API_KEY=sk-...
# OPENAI_EMBED_MODEL=text-embedding-3-small      # or text-embedding-3-large
# OPENAI_EMBED_DIM=                              # blank → use model's native dim
# OPENAI_BASE_URL=                               # for Azure / vLLM / LiteLLM gateways
# OPENAI_EMBED_BATCH_SIZE=96
# OPENAI_TIMEOUT_S=30.0

# ─── LM Studio adapter (deprecated; LM Studio retired in TheForge PR #168) ─────
# These settings are retained for reference / backward compatibility but are no
# longer used at startup. When a future rerank backend lands, these will be
# replaced by its own configuration block. Do not set LM_STUDIO_URL in new
# deployments — leave it empty.
# LM_STUDIO_URL=http://localhost:1234
# LM_STUDIO_EMBED_MODEL=CodeRankEmbed
# LM_STUDIO_RERANK_MODEL=CodeRankLLM
# LM_STUDIO_TIMEOUT=30

# ─── M365 / Entra ID OAuth (Phase 1 of TEAM_DEPLOYMENT_PLAN) ─────────────────
# The Code Indexer validates bearer tokens issued by TheForge.  Tokens are
# validated against the JWKS for the Navistone tenant; the audience must
# match AZURE_API_AUDIENCE.  See DEVOPS_REQUEST.md §1 for app-registration
# setup.  Leaving these blank in dev disables auth and accepts all calls
# from localhost (matches FORGE_ENV=development behaviour in TheForge).
#
# AZURE_TENANT_ID=<DEVOPS-PROVIDED>
# AZURE_API_CLIENT_ID=<DEVOPS-PROVIDED>
# AZURE_API_AUDIENCE=api://forge-api
# AZURE_JWKS_URI=https://login.microsoftonline.com/<TENANT_ID>/discovery/v2.0/keys

# ─── Shared service-to-service auth (matches TheForge FORGE_SERVICE_AUTH_TOKEN) ─
# In prod, every request from TheForge to /api/code-indexer/* carries this
# token.  Must be IDENTICAL to the value in TheForge/.env.  Generate with
# `openssl rand -base64 32` and store in 1Password vault `forge-prod`.
# Rotate every 90 days using the rolling rotation procedure.
# Leave blank in dev (FORGE_ENV=development → implicit localhost trust).
FORGE_ENV=development
FORGE_SERVICE_AUTH_TOKEN=

# ─── Persistent storage paths (Phase 2 of TEAM_DEPLOYMENT_PLAN) ──────────────
# When the persistent job-state SQLite DB lands, this is where it lives.
# Local dev: relative path inside the repo.
# Prod: point at the persistent volume mount.
#   JOBS_DB_PATH=/var/lib/forge/jobs/jobs.sqlite
JOBS_DB_PATH=.cgr/jobs.sqlite

# ─── S3 snapshot / restore (BUC-1499) ───────────────────────────────────────
# On startup the service downloads any absent/stale index files from S3 so a
# fresh container picks up the last committed graph immediately.  On clean
# shutdown it uploads changed .db and .duck files back to S3.
# Requires AWS credentials with s3:GetObject + s3:PutObject + s3:ListBucket.
# Set S3_INDEX_BUCKET="" to disable S3 sync entirely (local dev default).
S3_INDEX_BUCKET=navistone-forge-data
S3_INDEX_PREFIX=code-indexer/indexes
S3_INDEX_REGION=us-east-1

# ─── Grafana / Prometheus metrics (Phase 4) ──────────────────────────────────
# When true, exposes /metrics in Prometheus exposition format.  Scraped by
# the central Grafana Agent / Alloy — see DEVOPS_REQUEST.md §5.
METRICS_ENABLED=true
METRICS_PATH=/metrics

# ─── Code Indexer base URL (consumed by TheForge) ────────────────────────────
# IMPORTANT — port flow:
#   - When `pnpm dev` boots TheForge, scripts/start-indexer.sh launches
#     this service on :8003. TheForge's .env.example sets
#     CODE_INDEXER_BASE_URL=http://localhost:8003 to match.
#   - In Docker / production, the service runs on :8000 inside its
#     container; the proxy uses http://code-indexer:8000.
#   - If you start the service MANUALLY (e.g. `uv run uvicorn ... --port 8000`)
#     for debugging, you MUST update CODE_INDEXER_BASE_URL in TheForge/.env
#     to match — otherwise the proxy returns 502 / 503 and the FE shows
#     "Code Indexer offline" with no other diagnostic.
#
# Local dev (pnpm dev path):  http://localhost:8003
# Local dev (manual launch):  whatever --port you passed
# Prod (container DNS):       http://code-indexer:8000
# Public (reverse-proxied):   https://forge.navistone.com/api/code-indexer
# CODE_INDEXER_BASE_URL=http://localhost:8003
