# Code Indexer Service — environment variables
# Copy to .env and fill in values.

# LadybugDB (embedded, no Docker required)
LADYBUG_DB_PATH=.cgr/graph.db
LADYBUG_BATCH_SIZE=1000

# Default repo to index when repo_path is omitted
TARGET_REPO_PATH=.

# Server bind
HOST=0.0.0.0
PORT=8000

# Optional: Code Indexer base URL (consumed by TheForge)
# CODE_INDEXER_BASE_URL=http://localhost:8000
