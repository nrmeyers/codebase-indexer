# Excludes for the `podman build .` / `docker build .` context (repo root).
# The engine is vendored at codebase_rag/, so the build context is just this
# repo (no parent dir / sibling code-graph-rag). These patterns keep caches,
# scratch DBs, and tests out of the image.

# Indexer-side junk
.venv/
.cgr/
.cgr-hash-cache.json
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.ruff_cache/
.mypy_cache/
service.log
*.log

# Tests aren't needed at runtime; the image stays slim and the build
# layer doesn't grow unnecessarily.
tests/

# Planning + ops docs
.planning/
docs/

# Editor / OS / git noise
.git/
.github/
.vscode/
.idea/
.DS_Store

# Ladybug + DuckDB scratch
*.db
*.duck
*.duck.wal
*.duck.tmp
*.db-wal
*.db-shm
*.sqlite
*.sqlite-shm
*.sqlite-wal
